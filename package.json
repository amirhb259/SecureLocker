{
  "name": "securelocker",
  "private": true,
  "version": "0.1.2",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:api": "tsx watch server/index.ts",
    "dev:all": "concurrently \"npm run dev:api\" \"npm run dev\"",
    "dev:desktop": "npm run tauri -- dev",
    "start": "node dist/server/index.js",
    "start:api": "tsx server/index.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p server/tsconfig.json --noEmit && tsc -p tsconfig.netlify.json --noEmit",
    "build": "tsc -p tsconfig.json --noEmit && vite build",
    "build:desktop": "npm run build",
    "build:api": "tsc -p server/tsconfig.json",
    "build:netlify": "npm run prisma:generate && npm run typecheck && vite build",
    "preview": "vite preview",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "db:seed": "prisma db seed",
    "tauri": "tauri",
    "release:build": "npm run tauri build",
    "release:latest-json": "node scripts/generate-latest-json.mjs",
    "version:bump": "node scripts/bump-version.mjs"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/space-grotesk": "^5.2.10",
    "@netlify/functions": "^5.2.0",
    "@prisma/client": "^6.19.3",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-autostart": "^2.5.1",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.6.0",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "argon2": "^0.44.0",
    "clsx": "^2.1.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^1.8.0",
    "motion": "^12.38.0",
    "nodemailer": "^8.0.5",
    "prisma": "^6.19.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "serverless-http": "^4.0.0",
    "typescript": "~5.8.3",
    "vite": "^7.3.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "concurrently": "^9.2.1",
    "fast-check": "^4.7.0",
    "tsx": "^4.21.0",
    "vitest": "^4.1.5"
  }
}
