{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SecureLocker",
  "version": "0.1.0",
  "identifier": "com.securelocker.app",
  "build": {
    "beforeDevCommand": "npm run dev:all",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build:desktop",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "SecureLocker",
        "width": 1220,
        "height": 780,
        "minWidth": 900,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "resources/backend"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/64x64.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
