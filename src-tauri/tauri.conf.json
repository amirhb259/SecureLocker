{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SecureLocker",
  "version": "0.1.2",
  "identifier": "com.securelocker.app",
  "build": {
    "beforeDevCommand": "npm run dev:all",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "SecureLocker",
        "width": 1220,
        "height": 780,
        "minWidth": 900,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [],
    "icon": [
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/amirhb259/SecureLocker/releases/latest/download/latest.json"
      ],
      "dialog": false,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEMxRDFGMDQ5RTIxMTAxREEKUldUYUFSSGlTZkRSd1pOZlpFcGxPMG5Sa1NRckQ0bWQ3dWhQdWM2RW44ZUQ1clNpZzJxSnVVZ0YK"
    }
  }
}
