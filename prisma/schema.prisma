generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                          String                       @id @default(uuid()) @db.Uuid
  username                    String                       @unique @db.VarChar(32)
  email                       String                       @unique @db.VarChar(320)
  passwordHash                String                       @map("password_hash")
  emailVerifiedAt             DateTime?                    @map("email_verified_at")
  email2faEnabled             Boolean                      @default(false) @map("email_2fa_enabled")
  accountStatus               UserAccountStatus            @default(ACTIVE) @map("account_status")
  createdAt                   DateTime                     @default(now()) @map("created_at")
  updatedAt                   DateTime                     @updatedAt @map("updated_at")
  lockedAt                    DateTime?                    @map("locked_at")
  lockedReason                String?                      @map("locked_reason") @db.VarChar(128)
  emergencyShortcutEnabled    Boolean                      @default(false) @map("emergency_shortcut_enabled")
  emergencyShortcutHash       String?                      @map("emergency_shortcut_hash")
  emergencyShortcutCreatedAt  DateTime?                    @map("emergency_shortcut_created_at")
  emergencyShortcutUpdatedAt  DateTime?                    @map("emergency_shortcut_updated_at")
  accountLockEvents           AccountLockEvent[]
  accountRecoveryTokens       AccountRecoveryToken[]
  auditLogs                   AuditLog[]
  destructiveActionCodes      DestructiveActionCode[]
  verificationTokens          EmailVerificationToken[]
  passwordHistory             PasswordHistory[]
  passwordResetTokens         PasswordResetToken[]
  recoveryAttempts            RecoveryAttempt[]
  securityActionTokens        SecurityActionToken[]
  securityEvents              SecurityEvent[]
  securityQuestionSetupTokens SecurityQuestionSetupToken[]
  sessions                    Session[]
  trustedIps                  TrustedIp[]
  vault                       Vault?
  vaultActivities             VaultActivity[]
  vaultCredentials            VaultCredential[]
  securityQuestionAnswers     UserSecurityQuestion[]
  email2faCodes               Email2faCode[]
  email2faPendingSessions     Email2faPendingSession[]
  email2faAuditLogs           Email2faAuditLog[]
  securitySettings            SecuritySettings?
  trustedDevices              TrustedDevice[]
  pendingLoginApprovals       PendingLoginApproval[]
  securityLogs                SecurityLog[]
  emergencyShortcutSetupTokens EmergencyShortcutSetupToken[]

  @@map("users")
}

model Vault {
  id                       String            @id @default(uuid()) @db.Uuid
  userId                   String            @unique @map("user_id") @db.Uuid
  kdfSalt                  String            @map("kdf_salt") @db.VarChar(128)
  kdfIterations            Int               @map("kdf_iterations")
  encryptedDataKey         String            @map("encrypted_data_key")
  dataKeyNonce             String            @map("data_key_nonce") @db.VarChar(64)
  recoveryEncryptedDataKey String            @map("recovery_encrypted_data_key")
  recoveryDataKeyNonce     String            @map("recovery_data_key_nonce") @db.VarChar(64)
  createdAt                DateTime          @default(now()) @map("created_at")
  updatedAt                DateTime          @updatedAt @map("updated_at")
  credentials              VaultCredential[]
  user                     User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("vaults")
}

model VaultCredential {
  id         String          @id @default(uuid()) @db.Uuid
  vaultId    String          @map("vault_id") @db.Uuid
  userId     String          @map("user_id") @db.Uuid
  ciphertext String
  nonce      String          @db.VarChar(64)
  createdAt  DateTime        @default(now()) @map("created_at")
  updatedAt  DateTime        @updatedAt @map("updated_at")
  activities VaultActivity[]
  vault      Vault           @relation(fields: [vaultId], references: [id], onDelete: Cascade)
  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([vaultId, updatedAt])
  @@index([userId, updatedAt])
  @@map("vault_credentials")
}

model VaultActivity {
  id           String           @id @default(uuid()) @db.Uuid
  userId       String           @map("user_id") @db.Uuid
  credentialId String?          @map("credential_id") @db.Uuid
  action       String           @db.VarChar(64)
  createdAt    DateTime         @default(now()) @map("created_at")
  credential   VaultCredential? @relation(fields: [credentialId], references: [id], onDelete: SetNull)
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([credentialId])
  @@map("vault_activities")
}

model EmailVerificationToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("email_verification_tokens")
}

model PasswordResetToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

model Session {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  tokenHash  String    @unique @map("token_hash")
  expiresAt  DateTime  @map("expires_at")
  revokedAt  DateTime? @map("revoked_at")
  lastUsedAt DateTime  @default(now()) @map("last_used_at")
  ipAddress  String?   @map("ip_address") @db.VarChar(64)
  userAgent  String?   @map("user_agent") @db.VarChar(512)
  createdAt  DateTime  @default(now()) @map("created_at")
  auditLogs  AuditLog[]
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model LoginAttempt {
  id        String   @id @default(uuid()) @db.Uuid
  email     String?  @db.VarChar(320)
  ipAddress String   @map("ip_address") @db.VarChar(64)
  success   Boolean
  reason    String?  @db.VarChar(64)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([email, createdAt])
  @@index([ipAddress, createdAt])
  @@map("login_attempts")
}

model AuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String?  @map("user_id") @db.Uuid
  sessionId String?  @map("session_id") @db.Uuid
  action    String   @db.VarChar(64)
  details   String?  @db.VarChar(512)
  ipAddress String   @map("ip_address") @db.VarChar(64)
  userAgent String?  @map("user_agent") @db.VarChar(512)
  createdAt DateTime @default(now()) @map("created_at")
  session   Session? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([action, createdAt])
  @@index([ipAddress, createdAt])
  @@index([sessionId])
  @@index([userId, createdAt])
  @@map("audit_logs")
}

model DestructiveActionCode {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  codeHash  String    @map("code_hash")
  action    String    @db.VarChar(32)
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
  @@index([userId])
  @@map("destructive_action_codes")
}

model PasswordHistory {
  id                  String   @id @default(uuid()) @db.Uuid
  userId              String   @map("user_id") @db.Uuid
  passwordHash        String   @map("password_hash")
  passwordFingerprint String   @map("password_fingerprint") @db.VarChar(128)
  createdAt           DateTime @default(now()) @map("created_at")
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("password_history")
}

model UsernameReservation {
  id        String   @id @default(uuid()) @db.Uuid
  username  String   @unique @db.VarChar(32)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("username_reservations")
}

model TrustedIp {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  ipAddress   String   @map("ip_address") @db.VarChar(64)
  userAgent   String?  @map("user_agent") @db.VarChar(512)
  trustedAt   DateTime @default(now()) @map("trusted_at")
  firstSeenAt DateTime @default(now()) @map("first_seen_at")
  lastSeenAt  DateTime @default(now()) @map("last_seen_at")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, ipAddress])
  @@index([ipAddress])
  @@map("trusted_ips")
}

model SecurityEvent {
  id           String                @id @default(uuid()) @db.Uuid
  userId       String                @map("user_id") @db.Uuid
  ipAddress    String                @map("ip_address") @db.VarChar(64)
  userAgent    String?               @map("user_agent") @db.VarChar(512)
  type         SecurityEventType
  status       SecurityEventStatus   @default(PENDING)
  action       String?               @db.VarChar(128)
  attemptCount Int                   @default(1) @map("attempt_count")
  resolvedAt   DateTime?             @map("resolved_at")
  expiresAt    DateTime?             @map("expires_at")
  createdAt    DateTime              @default(now()) @map("created_at")
  updatedAt    DateTime              @updatedAt @map("updated_at")
  actionTokens SecurityActionToken[]
  user         User                  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([ipAddress, createdAt])
  @@index([expiresAt])
  @@map("security_events")
}

model SecurityActionToken {
  id        String             @id @default(uuid()) @db.Uuid
  userId    String             @map("user_id") @db.Uuid
  eventId   String             @map("event_id") @db.Uuid
  tokenHash String             @unique @map("token_hash")
  action    SecurityActionType
  expiresAt DateTime           @map("expires_at")
  usedAt    DateTime?          @map("used_at")
  createdAt DateTime           @default(now()) @map("created_at")
  event     SecurityEvent      @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([eventId])
  @@index([expiresAt])
  @@map("security_action_tokens")
}

model SecurityQuestion {
  id        String                 @id @default(uuid()) @db.Uuid
  prompt    String                 @unique @db.VarChar(180)
  isActive  Boolean                @default(true) @map("is_active")
  createdAt DateTime               @default(now()) @map("created_at")
  answers   UserSecurityQuestion[]

  @@map("security_questions")
}

model UserSecurityQuestion {
  id         String           @id @default(uuid()) @db.Uuid
  userId     String           @map("user_id") @db.Uuid
  questionId String           @map("question_id") @db.Uuid
  answerHash String           @map("answer_hash")
  createdAt  DateTime         @default(now()) @map("created_at")
  updatedAt  DateTime         @updatedAt @map("updated_at")
  question   SecurityQuestion @relation(fields: [questionId], references: [id])
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, questionId])
  @@index([userId])
  @@map("user_security_questions")
}

model SecurityQuestionSetupToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("security_question_setup_tokens")
}

model EmergencyShortcutSetupToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("emergency_shortcut_setup_tokens")
}

model AccountRecoveryToken {
  id        String            @id @default(uuid()) @db.Uuid
  userId    String            @map("user_id") @db.Uuid
  tokenHash String            @unique @map("token_hash")
  expiresAt DateTime          @map("expires_at")
  usedAt    DateTime?         @map("used_at")
  createdAt DateTime          @default(now()) @map("created_at")
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  attempts  RecoveryAttempt[]

  @@index([userId])
  @@index([expiresAt])
  @@map("account_recovery_tokens")
}

model RecoveryAttempt {
  id        String                @id @default(uuid()) @db.Uuid
  userId    String                @map("user_id") @db.Uuid
  tokenId   String?               @map("token_id") @db.Uuid
  ipAddress String                @map("ip_address") @db.VarChar(64)
  userAgent String?               @map("user_agent") @db.VarChar(512)
  success   Boolean
  reason    String?               @db.VarChar(128)
  createdAt DateTime              @default(now()) @map("created_at")
  token     AccountRecoveryToken? @relation(fields: [tokenId], references: [id])
  user      User                  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([ipAddress, createdAt])
  @@map("recovery_attempts")
}

model AccountLockEvent {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  reason     String    @db.VarChar(128)
  ipAddress  String    @map("ip_address") @db.VarChar(64)
  userAgent  String?   @map("user_agent") @db.VarChar(512)
  createdAt  DateTime  @default(now()) @map("created_at")
  resolvedAt DateTime? @map("resolved_at")
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("account_lock_events")
}

enum SecurityEventType {
  NEW_IP_LOGIN
  SUSPICIOUS_LOGIN
  ACCOUNT_LOCKED
}

enum SecurityEventStatus {
  PENDING
  TRUSTED
  SUSPICIOUS
  LOCKED
  EXPIRED
}

enum SecurityActionType {
  TRUST_IP
  SECURE_ACCOUNT
}

enum UserAccountStatus {
  ACTIVE
  LOCKED
  SCHEDULED_DELETION
  DEACTIVATED
  EMERGENCY_LOCKED
}

model Email2faCode {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  codeHash  String    @map("code_hash") @db.VarChar(128)
  purpose   String    @db.VarChar(32)
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("email_2fa_codes")
}

model Email2faPendingSession {
  id               String    @id @default(uuid()) @db.Uuid
  userId           String    @map("user_id") @db.Uuid
  sessionTokenHash String    @unique @map("session_token_hash") @db.VarChar(128)
  ipAddress        String?   @map("ip_address") @db.VarChar(64)
  userAgent        String?   @map("user_agent") @db.VarChar(512)
  expiresAt        DateTime  @map("expires_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("email_2fa_pending_sessions")
}

model Email2faAuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  action    String   @db.VarChar(64)
  ipAddress String?  @map("ip_address") @db.VarChar(64)
  userAgent String?  @map("user_agent") @db.VarChar(512)
  details   String?  @map("details") @db.VarChar(512)
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@map("email_2fa_audit_logs")
}

// Advanced Security System Tables
model SecuritySettings {
  id                String   @id @default(uuid()) @db.Uuid
  userId            String   @unique @map("user_id") @db.Uuid
  loginAlerts       Boolean  @default(true) @map("login_alerts")
  suspiciousLoginDetection Boolean @default(true) @map("suspicious_login_detection")
  deviceTrustSystem Boolean  @default(true) @map("device_trust_system")
  accountLockProtection Boolean @default(true) @map("account_lock_protection")
  maxFailedAttempts Int      @default(5) @map("max_failed_attempts")
  lockDurationMinutes Int     @default(10) @map("lock_duration_minutes")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("security_settings")
}

model TrustedDevice {
  id                    String    @id @default(uuid()) @db.Uuid
  userId                String    @map("user_id") @db.Uuid
  deviceName            String    @map("device_name") @db.VarChar(128)
  ipHash                String    @map("ip_hash") @db.VarChar(128)
  userAgentHash         String    @map("user_agent_hash") @db.VarChar(128)
  deviceFingerprintHash String    @map("device_fingerprint_hash") @db.VarChar(128)
  firstSeenAt           DateTime  @default(now()) @map("first_seen_at")
  lastSeenAt            DateTime  @default(now()) @map("last_seen_at")
  trustedAt             DateTime  @default(now()) @map("trusted_at")
  revokedAt             DateTime? @map("revoked_at")
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, deviceFingerprintHash, ipHash])
  @@index([userId])
  @@index([deviceFingerprintHash])
  @@index([ipHash])
  @@map("trusted_devices")
}

model PendingLoginApproval {
  id                    String    @id @default(uuid()) @db.Uuid
  userId                String    @map("user_id") @db.Uuid
  tokenHash             String    @unique @map("token_hash") @db.VarChar(128)
  ipHash                String    @map("ip_hash") @db.VarChar(128)
  userAgentHash         String    @map("user_agent_hash") @db.VarChar(128)
  deviceFingerprintHash String    @map("device_fingerprint_hash") @db.VarChar(128)
  deviceName            String    @map("device_name") @db.VarChar(128)
  expiresAt             DateTime  @map("expires_at")
  approvedAt            DateTime? @map("approved_at")
  rejectedAt            DateTime? @map("rejected_at")
  createdAt             DateTime  @default(now()) @map("created_at")
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([userId, deviceFingerprintHash, ipHash])
  @@map("pending_login_approvals")
}

model SecurityLog {
  id          String           @id @default(uuid()) @db.Uuid
  userId      String           @map("user_id") @db.Uuid
  action      SecurityLogAction
  ipAddress   String           @map("ip_address") @db.VarChar(64)
  userAgent   String?          @map("user_agent") @db.VarChar(512)
  details     String?          @db.VarChar(512)
  severity    SecurityLogSeverity @default(INFO)
  createdAt   DateTime         @default(now()) @map("created_at")
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([action, createdAt])
  @@index([severity, createdAt])
  @@map("security_logs")
}

enum SecurityLogAction {
  LOGIN_SUCCESS
  LOGIN_FAILED
  NEW_DEVICE_DETECTED
  NEW_DEVICE_LOGIN
  SUSPICIOUS_LOGIN_BLOCKED
  LOGIN_APPROVAL_REQUESTED
  APPROVAL_EMAIL_SENT
  LOGIN_APPROVED
  LOGIN_REJECTED
  ACCOUNT_LOCKED
  ACCOUNT_UNLOCKED
  PASSWORD_CHANGED
  TFA_ENABLED
  TFA_DISABLED
  DEVICE_TRUSTED
  DEVICE_UNTRUSTED
  EMERGENCY_SHORTCUT_SETUP_REQUESTED
  EMERGENCY_SHORTCUT_ENABLED
  EMERGENCY_SHORTCUT_TRIGGERED
  EMERGENCY_LOCK_UNLOCK_ATTEMPT
  EMERGENCY_LOCK_UNLOCK_SUCCESS
  EMERGENCY_SHORTCUT_DISABLED
}

enum SecurityLogSeverity {
  INFO
  WARNING
  ERROR
  CRITICAL
}

